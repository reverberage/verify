{
  "$schema": "https://opencode.ai/config.json",
  "model": "qwen/{model}",
  "disabled_providers": ["alibaba"],
  "provider": {
    "qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen (Alibaba Model Studio)",
      "options": {
        "baseURL": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
        "apiKey": "{env:DASHSCOPE_API_KEY}"
      },
      "models": {
        "qwen3-coder-plus": { "name": "Qwen3 Coder Plus" },
        "qwen3-coder-flash": { "name": "Qwen3 Coder Flash" },
        "qwen3.7-plus": { "name": "Qwen3.7 Plus (multimodal: image+video)" },
        "qwen3.7-max": { "name": "Qwen3.7 Max" },
        "qwen3.6-plus": { "name": "Qwen3.6 Plus (multimodal: image+video)" },
        "qwen3.6-flash": { "name": "Qwen3.6 Flash (multimodal: image+video)" },
        "qwen3-vl-plus": { "name": "Qwen3 VL Plus (vision-language)" },
        "qwen3-vl-flash": { "name": "Qwen3 VL Flash (vision-language)" },
        "qwen-vl-max": { "name": "Qwen VL Max (vision-language)" },
        "qwen-vl-plus": { "name": "Qwen VL Plus (vision-language)" },
        "qwq-plus": { "name": "QwQ Plus (reasoning)" },
        "deepseek-v3.2": { "name": "DeepSeek V3.2" },
        "glm-5.2": { "name": "GLM 5.2" },
        "kimi-k2.7-code": { "name": "Kimi K2.7 Code" }
      }
    }
  },
  "command": {
    "sdd-new": {
      "template": "Run the full 8-phase SDD pipeline for the given change. Use the SDD skills under .opencode/skills/ and delegate to sdd subagents via the task tool for phases 1-5, then implement for phase 6, verify with sdd-verifier for phase 7, and archive with sdd-archiver for phase 8. Run sequentially: explore -> propose -> spec -> design -> tasks -> apply -> verify -> archive. Change: $ARGUMENTS",
      "description": "Run full Spec-Driven Development pipeline"
    }
  },
  "default_agent": "n3rverberage",
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/*.md"
  ],
  "plugin": [
    ".opencode/plugins/n3rverberage-lifecycle.js",
    ".opencode/plugins/n3rverberage-shell-env.js"
  ],
  "tools": {
    "websearch": true
  },
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "mcp": {
    "n3rverberage-memory": {
      "type": "local",
      "command": ["n3rverberage-memory"],
      "environment": {"N3RVERBERAGE_AGENT_SOURCE": "opencode"}
    },
    "n3rverberage-hub": {
      "type": "local",
      "command": ["n3rverberage-hub"],
      "environment": {"N3RVERBERAGE_AGENT_SOURCE": "opencode"}
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@github/github-mcp-server"],
      "environment": {"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"}
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking@latest"]
    }
  }
}